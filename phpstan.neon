includes:
    - ./vendor/nunomaduro/larastan/extension.neon

parameters:
    paths:
        - app
    excludePaths:
        - ./app/Admin
    # The level 8 is the highest level
    level: 3
    checkMissingIterableValueType: false
    ignoreErrors:
        - '#Unsafe usage of new static#'
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::(.*?)\(\).#'

